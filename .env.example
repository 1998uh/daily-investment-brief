# OpenAI-compatible configuration.
# DeepSeek example:
# BRIEF_BASE_URL=https://api.deepseek.com/v1
# BRIEF_MODEL=deepseek-chat
# BRIEF_API_KEY=sk-...

# OpenAI example:
# BRIEF_BASE_URL=https://api.openai.com/v1
# BRIEF_MODEL=gpt-4.1
# BRIEF_API_KEY=sk-...

BRIEF_BASE_URL=
BRIEF_MODEL=
BRIEF_API_KEY=

# LLM request behavior.
BRIEF_LLM_TIMEOUT_SECONDS=120
BRIEF_LLM_RETRIES=2
BRIEF_LLM_RETRY_DELAY_SECONDS=2

# Brief defaults.
BRIEF_TIMEZONE=Asia/Shanghai
BRIEF_WINDOW_START=08:00
BRIEF_WINDOW_END=08:00
BRIEF_MARKETS=A股,港股
BRIEF_STYLE=strong_narrative_emoji
BRIEF_MAX_CHARS_PER_ARTICLE=6000
BRIEF_BATCH_SIZE=8
BRIEF_TEMPERATURE=0.2

# Optional cookies for collectors. Prefer short-lived cookies copied from your
# own logged-in browser session; never put account passwords here.
XUEQIU_COOKIE=
WEIBO_COOKIE=
WECHAT_COOKIE=

# Agent system
AGENT_MEMORY_DIR=memory
AGENT_DB_NAME=agent.db
AGENT_CHROMA_DIR=chroma
AGENT_SOURCES_DIR=sources
AGENT_REPORTS_DIR=reports
AGENT_JWT_SECRET=change-me-in-production
AGENT_JWT_ALGORITHM=HS256
AGENT_JWT_EXPIRE_MINUTES=10080
TAVILY_API_KEY=tvly-...

# ─── Docker Compose ────────────────────────────────────────────────
# Host port mappings
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Host paths (defaults work if running from project root)
MEMORY_DIR=./memory
SOURCES_DIR=./sources
REPORTS_DIR=./reports
