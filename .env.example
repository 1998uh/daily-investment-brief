# LLM provider: openai (default), openai-responses, anthropic, gemini, or ollama.
# Most relay services and providers such as DeepSeek, OpenAI, DashScope,
# Moonshot, Zhipu, OpenRouter, SiliconFlow, Groq, and local vLLM use openai.
BRIEF_LLM_PROVIDER=openai
BRIEF_BASE_URL=
BRIEF_MODEL=
BRIEF_API_KEY=

# LLM request behavior.
BRIEF_LLM_TIMEOUT_SECONDS=120
BRIEF_LLM_RETRIES=2
BRIEF_LLM_RETRY_DELAY_SECONDS=2
BRIEF_LLM_BATCH_CONCURRENCY=3
# Optional provider-specific fields. BRIEF_LLM_THINKING is mainly for
# OpenAI-compatible providers that accept a `thinking` request field.
BRIEF_LLM_THINKING=
BRIEF_LLM_MAX_TOKENS=

# Brief defaults.
BRIEF_TIMEZONE=Asia/Shanghai
BRIEF_WINDOW_START=08:00
BRIEF_WINDOW_END=08:00
BRIEF_MARKETS=A股,港股
BRIEF_STYLE=strong_narrative_emoji
BRIEF_MAX_CHARS_PER_ARTICLE=6000
BRIEF_BATCH_SIZE=8
BRIEF_BATCH_MAX_CHARS=15000
BRIEF_TEMPERATURE=0.2

# Optional cookies for collectors. Prefer short-lived cookies copied from your
# own logged-in browser session; never put account passwords here.
XUEQIU_COOKIE=
WEIBO_COOKIE=
WECHAT_COOKIE=

# Agent system
AGENT_MEMORY_DIR=memory
AGENT_DB_NAME=agent.db
AGENT_CHROMA_DIR=chroma
AGENT_SOURCES_DIR=sources
AGENT_REPORTS_DIR=reports
AGENT_JWT_SECRET=change-me-in-production
AGENT_JWT_ALGORITHM=HS256
AGENT_JWT_EXPIRE_MINUTES=10080
TAVILY_API_KEY=tvly-...

# ─── Docker Compose ────────────────────────────────────────────────
# Host port mappings
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Host paths (defaults work if running from project root)
MEMORY_DIR=./memory
SOURCES_DIR=./sources
REPORTS_DIR=./reports
